# === LOCAL DEVELOPMENT ===
# Just copy this to .env.local and you're ready to go!

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/sahakum_khmer_dev"
NEXTAUTH_SECRET="local-dev-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# === EMAIL NOTIFICATIONS ===
# Gmail SMTP configuration for sending notifications
# EMAIL_FROM: Your Gmail address (e.g., contact.sahakumkhmer.se@gmail.com)
# EMAIL_APP_PASSWORD: Gmail App Password (NOT your regular password)
# Get App Password from: https://myaccount.google.com/apppasswords
# MEMBERSHIP_NOTIFICATION_EMAILS: Comma-separated list of emails to notify (optional)
# If not set, sends to all ADMIN and BOARD users in database

# EMAIL_FROM="your-gmail@gmail.com"
# EMAIL_APP_PASSWORD="your-app-password-here"
# MEMBERSHIP_NOTIFICATION_EMAILS="board1@example.com,board2@example.com"

# === OAUTH (GOOGLE & FACEBOOK LOGIN) ===
# Enable social login for members. Get credentials from:
# Google: https://console.cloud.google.com/apis/credentials
# Facebook: https://developers.facebook.com/apps/
#
# Add these redirect URIs in your OAuth app settings:
# Google: {NEXTAUTH_URL}/api/auth/callback/google
# Facebook: {NEXTAUTH_URL}/api/auth/callback/facebook
# Example (prod): https://www.sahakumkhmer.se/api/auth/callback/google
#
# Set to "true" to show the sign-in buttons (must match server config)
# NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED="true"
# NEXT_PUBLIC_OAUTH_FACEBOOK_ENABLED="true"
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Optional: Separate credentials for local dev (if "OAuth client was not found" locally)
# Create a 2nd OAuth client in Google Console with redirect: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID_DEV="..."
# GOOGLE_CLIENT_SECRET_DEV="..."
# FACEBOOK_CLIENT_ID="your-facebook-app-id"
# FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# === ANALYTICS ===
# Google Analytics 4 - Only active in production
# Get this from: https://analytics.google.com/analytics/web/ → Admin → Data Streams → Web → Measurement ID
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# === PRODUCTION DEPLOYMENT ===
# These are set as Vercel environment variables:
# DATABASE_URL="postgresql://user:pass@host:port/dbname"
# DIRECT_URL="postgresql://user:pass@host:port/dbname"
# NEXTAUTH_SECRET="production-secret"
# NEXTAUTH_URL="https://yourdomain.vercel.app"

# === GOOGLE CLOUD STORAGE (PRODUCTION ONLY) ===
# Required for production file storage:
# GOOGLE_CLOUD_PROJECT_ID="your-project-id"
# GOOGLE_CLOUD_BUCKET_NAME="your-bucket-name"

# Option 1: JSON content (recommended for Vercel)
# GOOGLE_CLOUD_KEY_FILE='{"type":"service_account","project_id":"your-project","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"service@project.iam.gserviceaccount.com",...}'

# Option 2: File path (for local development)
# GOOGLE_CLOUD_KEY_FILE="/path/to/service-account-key.json"

# Important: Your bucket must have uniform bucket-level access enabled
# Service account requires "Storage Object Admin" role for file operations
# If not set, uses Google Cloud default credentials (Application Default Credentials)

# === MEDIA SYNC OPTIONS ===
# In production, you can sync from both local files and Google Cloud Storage:
# POST /api/media/sync?hybrid=true
# This is useful for migrating local files to cloud storage or hybrid deployments